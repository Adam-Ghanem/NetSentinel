# NetSentinel configuration template
# Copy this file to .env for local development. Never commit the resulting .env file.

# Runtime environment: development, test, or production
ENVIRONMENT=development

# SQLAlchemy database URL
DATABASE_URL=sqlite:///netsentinel.db

# Local-only convenience. Production must set this to false and use Alembic migrations.
AUTO_CREATE_SCHEMA=true

# Optional threat-intelligence credentials
# Leave these values empty until valid keys are supplied through a local secret store.
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=

# Logging: DEBUG, INFO, WARNING, ERROR, or CRITICAL
LOG_LEVEL=INFO

# Demo mode is disabled by default and is rejected in production.
DEMO_MODE=false
